# Postgres — same instance as main app, osint schema
DATABASE_URL=postgresql://pharos:pharos@localhost:5434/pharos

# Redis — BullMQ backend + cache
REDIS_URL=redis://localhost:6382

# MinIO — local S3-compatible bucket (minio console at localhost:9001)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=osint-raw

# NASA FIRMS — get free key at https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=

# Wingbits GPS Jam — get free key at https://wingbits.com
WINGBITS_API_KEY=

# AISStream — vessel tracking WebSocket (free key from https://aisstream.io)
AISSTREAM_API_KEY=

# Cloudflare Radar — free token from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Server
PORT=4000
