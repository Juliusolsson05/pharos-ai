# Postgres — same instance as main app, osint schema
DATABASE_URL=postgresql://pharos:pharos@localhost:5434/pharos

# Redis — BullMQ backend + cache
REDIS_URL=redis://localhost:6382

# MinIO — local S3-compatible bucket (minio console at localhost:9001)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=osint-raw

# Server
PORT=4000
